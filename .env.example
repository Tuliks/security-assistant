# Copy to .env and fill in ONE provider. Pydantic AI reads these automatically.
# .env is git-ignored — never commit real keys.

# --- OpenAI (default) ---
OPENAI_API_KEY=sk-proj-...
AGENT_MODEL=openai:gpt-4.1

# --- OpenAI GPT-5 (as the spec suggests — just change the model line) ---
# AGENT_MODEL=openai:gpt-5.1

# --- Anthropic (alternative — change both lines) ---
# ANTHROPIC_API_KEY=sk-ant-api03-...
# AGENT_MODEL=anthropic:claude-opus-4-8
